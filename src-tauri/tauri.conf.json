{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keyfount",
  "version": "0.1.0",
  "identifier": "io.keyfount.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Keyfount",
        "width": 1120,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "fullscreen": false,
        "center": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["hudWindow", "underWindowBackground"],
          "state": "active",
          "radius": 16.0
        }
      }
    ],
    "macOSPrivateApi": true,
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://*; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "category": "Productivity",
    "copyright": "Copyright (c) 2026 Keyfount",
    "shortDescription": "Deterministic password manager.",
    "longDescription": "Keyfount derives your passwords from a master password, a domain, and an email — locally, without storing them. No vault, no cloud sync required, just an algorithm.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": ["en-US", "fr-FR"]
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/Keyfount/desktop/releases/latest/download/latest.json"],
      "dialog": false,
      "pubkey": ""
    }
  }
}
