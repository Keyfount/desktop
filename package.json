{
  "name": "keyfount-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic password manager desktop app (macOS, Windows, iOS, Android). No vault, no sync, just an algorithm.",
  "license": "MIT",
  "homepage": "https://github.com/Keyfount/desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keyfount/desktop.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev",
    "dev:ios": "tauri ios dev",
    "dev:android": "tauri android dev",
    "build": "vite build",
    "build:tauri": "tauri build",
    "build:ios": "tauri ios build",
    "build:android": "tauri android build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:rust": "cd src-tauri && cargo test --all-features",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "format": "prettier --write . && cd src-tauri && cargo fmt",
    "format:check": "prettier --check . && cd src-tauri && cargo fmt -- --check"
  },
  "dependencies": {
    "@cloudflare/opaque-ts": "^0.7.5",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@preact/signals": "^2.9.0",
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "@tauri-apps/plugin-os": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-store": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.4.0",
    "framer-motion": "^12.39.0",
    "preact": "^10.29.2",
    "tldts": "^7.0.30"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.4.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "hash-wasm": "^4.12.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
